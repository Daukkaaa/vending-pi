[Unit]
Description=Vending Machine Kiosk UI (Vite Preview)
After=network.target

[Service]
Type=simple
User=rpi
WorkingDirectory=/home/rpi/vending-machine/kiosk-ui
ExecStart=/home/rpi/vending-machine/kiosk-ui/node_modules/.bin/vite preview --host 0.0.0.0 --port 5173
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
