# Backend server URL (your VPS where docker-compose runs)
SERVER_URL=ws://YOUR_SERVER_IP:8000
API_URL=http://YOUR_SERVER_IP:8000

# Machine ID (get from CRM after creating machine)
MACHINE_ID=
MACHINE_TOKEN=

# GPIO pins (BCM numbering)
RELAY_PIN=17
DOOR_SENSOR_PIN=27

# Lock duration (seconds)
LOCK_DURATION=30

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL=30
